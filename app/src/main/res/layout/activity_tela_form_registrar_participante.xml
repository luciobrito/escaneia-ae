<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".telas.TelaRegistrarParticipante"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Registrar Participante"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />

            <View
                android:layout_width="60dp"
                android:layout_height="4dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp"
                android:background="#40E0D0" />

            <TextView android:id="@+id/textView4" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" tools:ignore="MissingId" />
            <TextView android:id="@+id/textView5" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" tools:ignore="MissingId" />
            <TextView android:id="@+id/textView6" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" tools:ignore="MissingId" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:hint="Seu Nome"
                android:textColorHint="#888888"
                app:boxStrokeColor="#40E0D0"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="2.5dp"
                app:hintTextColor="#40E0D0"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <EditText
                    android:id="@+id/edtNome_FormRegistrarParticipante"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:ems="10"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:hint="Seu E-mail"
                android:textColorHint="#888888"
                app:boxStrokeColor="#40E0D0"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="2.5dp"
                app:hintTextColor="#40E0D0"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <EditText
                    android:id="@+id/edtEmail_FormRegistrarParticipante"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:ems="10"
                    android:inputType="textEmailAddress" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="36dp"
                android:hint="Seu RA"
                android:textColorHint="#888888"
                app:boxStrokeColor="#40E0D0"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="2.5dp"
                app:hintTextColor="#40E0D0"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <EditText
                    android:id="@+id/edtRa_FormRegistrarParticipante"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:ems="10"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegistrar_FormRegistrarParticipante"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:text="REGISTRAR"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#9333EA"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVoltar_FormRegistrarParticipante"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="VOLTAR"
                android:textSize="16sp"
                android:textColor="#9333EA"
                android:backgroundTint="@android:color/transparent"
                app:strokeColor="#9333EA"
                app:strokeWidth="2dp"
                app:cornerRadius="12dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>